# ─────────────────────────────────────────────────────────────
# TradeMe — variables de entorno (ejemplo, SIN valores reales)
# Copia a .env y rellena. Nunca subas .env al repo.
# ─────────────────────────────────────────────────────────────

# Cripto — Binance (los datos públicos NO requieren clave; M1 arranca sin clave)
BINANCE_API_KEY=
BINANCE_API_SECRET=

# Acciones — Alpaca (paper por defecto)
ALPACA_API_KEY_ID=
ALPACA_API_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Forex — Twelve Data u OANDA
TWELVEDATA_API_KEY=
OANDA_API_TOKEN=
OANDA_ACCOUNT_ID=

# Webhook de TradingView (señales tipo SniperUltra)
TV_WEBHOOK_SECRET=
EXTERNAL_SIGNALS_CONFIG=apps/api/config/external_signals.yaml
# CORS: orígenes separados por comas; vacío = permitir cualquiera (dev)
CORS_ORIGIN=

# Infraestructura
DATABASE_URL=postgres://trademe:trademe@localhost:5432/trademe
REDIS_URL=redis://localhost:6379

# apps/api
API_PORT=3001
API_HOST=0.0.0.0
LOG_LEVEL=info
TRADEME_SYMBOLS=BTCUSDT
TRADEME_INTERVALS=1m,5m,15m,30m,1h,4h,1d,1w

# apps/quant
MLFLOW_TRACKING_URI=file:./mlruns

# Seguridad / riesgo — la ejecución real SIEMPRE desactivada por defecto
ENABLE_LIVE_TRADING=false
# Capital para el sizing del plan de acción (M4)
ACCOUNT_EQUITY=10000

# M9 · Web Push (genera las tuyas en producción con: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:tu-correo@ejemplo.com
PUSH_MIN_CONFIDENCE=0.65
PUSH_COOLDOWN_MS=600000
