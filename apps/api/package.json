{
  "name": "@trademe/api",
  "version": "0.10.0",
  "private": true,
  "type": "module",
  "description": "TradeMe API (Node + TypeScript): tiempo real, WS, webhooks, inferencia en vivo.",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:parity": "vitest run test/parity.test.ts"
  },
  "dependencies": {
    "fastify": "^5.2.0",
    "ws": "^8.18.0",
    "zod": "^3.24.1",
    "pg": "^8.13.1",
    "technicalindicators": "^3.1.0",
    "yaml": "^2.6.1",
    "@fastify/cors": "^10.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^20.17.0",
    "@types/ws": "^8.5.13",
    "eslint": "^9.17.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0",
    "vitest": "^2.1.8",
    "@types/pg": "^8.11.10"
  }
}
